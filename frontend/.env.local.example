# ─────────────────────────────────────────────────────────────────
# RepoPilot Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────

# ─── Backend API URL ──────────────────────────────────────────────
# Development: point to your local Express server
# Production:  point to your Render deployment URL
NEXT_PUBLIC_API_URL=http://localhost:5000

# ─── Internal API Secret ──────────────────────────────────────────
# Must match the API_SECRET value in backend/.env exactly.
# Used to authenticate all frontend → backend API calls.
# Set this to any long random string (min 32 characters).
# Example: openssl rand -hex 32
NEXT_PUBLIC_API_SECRET=your_internal_api_secret_here

# ─────────────────────────────────────────────────────────────────
# PRODUCTION VALUES (Vercel Dashboard → Environment Variables)
# ─────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL    = https://repopilot-api.onrender.com
# NEXT_PUBLIC_API_SECRET = your_production_secret_here
# ─────────────────────────────────────────────────────────────────